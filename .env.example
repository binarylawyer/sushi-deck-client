# ── Supabase (Sushi-Kitchen project) ────────────────────────────────────────
# The hosted deck API + the app's own admin both talk to Supabase with the
# SERVICE ROLE key (server-side only — never expose it to the browser). The
# `decks` table has RLS enabled with no policies, so the service role is the
# only key that can read/write it.
SUPABASE_URL=https://awomcxrkxtxwkygoschf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Consumer API keys (BACKEND side) ────────────────────────────────────────
# JSON map of { "<api-key>": "<owner/tenant>" }. Each consumer (e.g. moye-law-os,
# and THIS app's own front-end — see below) gets a key that resolves to an owner;
# the server NEVER trusts a client-supplied tenant. Leave empty to disable the
# public REST API entirely.
#   e.g. {"<moye-key>":"moye-law-os","<self-key>":"sushi-deck"}
SUSHI_DECK_API_KEYS={}

# ── This app as an API CONSUMER (Option A: front-end-only) ───────────────────
# Under Option A the app's own pages/actions consume the deck API over HTTP
# instead of the database directly. Point these at THIS deployment's API and use
# a key whose owner matches the admin owner below (add it to SUSHI_DECK_API_KEYS).
#   SUSHI_DECK_API_URL: defaults to this deployment's own origin (VERCEL_URL) if
#   unset; set it explicitly for local dev / a custom domain.
SUSHI_DECK_API_URL=
SUSHI_DECK_API_KEY=

# Owner/tenant the app's own admin writes decks under (must match the owner that
# SUSHI_DECK_API_KEY resolves to in SUSHI_DECK_API_KEYS).
SUSHI_DECK_ADMIN_OWNER=sushi-deck

# Optional — only if Vercel Deployment Protection is left ON. Sent as the
# protection-bypass header so server-to-server / same-origin API calls aren't
# bounced to the SSO wall. Recommended alternative: disable Deployment Protection
# (the API has its own key auth + the admin gate).
VERCEL_AUTOMATION_BYPASS_SECRET=

# ── Admin gate (standalone app) ─────────────────────────────────────────────
# One password unlocks the admin UI. Store the HASH, not the password:
#   node -e "import('@binarylawyer/sushi-deck/gate').then(g=>console.log(g.hashPassword('your-password')))"
ADMIN_PASSWORD_HASH=
# Secret used to sign the admin session cookie (any long random string).
ADMIN_GATE_SECRET=

# ── AI generation (Claude) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-opus-4-8).
SUSHI_DECK_LLM_MODEL=claude-opus-4-8
